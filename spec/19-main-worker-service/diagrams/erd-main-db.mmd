    WorkerNode {
        INTEGER WorkerNodeId PK
        TEXT WorkerNodeTitle
        TEXT WorkerNodeIdentity UK
        TEXT WorkerNodeEndpoint
        INTEGER WorkerNodeStatusId FK
        INTEGER WorkerNodeKindId FK
        TEXT WorkerNodeRegisteredAt
        TEXT WorkerNodeLastSeenAt
        TEXT Description
    }
    WorkerNodeStatus {
        INTEGER WorkerNodeStatusId PK
        TEXT WorkerNodeStatusCode UK
        TEXT WorkerNodeStatusLabel
        TEXT Description
    }
    WorkerNodeKind {
        INTEGER WorkerNodeKindId PK
        TEXT WorkerNodeKindCode UK
        TEXT WorkerNodeKindLabel
        TEXT Description
    }
    Company {
        INTEGER CompanyId PK
        TEXT CompanySlug UK
        TEXT CompanyName
        INTEGER WorkerNodeId FK
        TEXT CompanyAssignedAt
        TEXT Description
    }
    User {
        INTEGER UserId PK
        TEXT UserEmail UK
        TEXT UserPasswordHash
        TEXT UserPasswordSalt
        INTEGER CompanyId FK
        TEXT UserCreatedAt
        TEXT UserTotpSecret
        TEXT UserTotpEnrolledAt
        TEXT UserTotpBackupCodesHash
        TEXT Description
    }
    Role {
        INTEGER RoleId PK
        TEXT RoleCode UK
        TEXT RoleLabel
        TEXT Description
    }
    UserRole {
        INTEGER UserRoleId PK
        INTEGER UserId FK
        INTEGER RoleId FK
    }
    EnumPage {
        INTEGER EnumPageId PK
        TEXT EnumPageCode UK
        TEXT EnumPageLabel
        TEXT Description
    }
