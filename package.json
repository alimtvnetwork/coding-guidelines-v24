{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "5.19.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync": "node scripts/sync-version.mjs && node scripts/sync-spec-tree.mjs && node scripts/sync-health-score.mjs && node scripts/sync-readme-stats.mjs",
    "sync:version": "node scripts/sync-version.mjs",
    "sync:specs": "node scripts/sync-spec-tree.mjs",
    "sync:readme": "node scripts/sync-readme-stats.mjs",
    "sync:health": "node scripts/sync-health-score.mjs",
    "sync:check": "node scripts/sync-check.mjs",
    "validate:version": "node scripts/validate-version-json.mjs",
    "gen:role-enum": "node scripts/generate-role-enum.mjs",
    "check:role-enum": "node scripts/check-role-enum.mjs",
    "sync:check:verbose": "node scripts/sync-check.mjs --verbose",
    "sync:fix": "node scripts/sync-check.mjs --fix",
    "lint:readme": "python3 linter-scripts/check-root-readme.py",
    "lint:readme:canonicals": "python3 linter-scripts/check-readme-canonicals.py",
    "lint:readme:install": "python3 linter-scripts/check-readme-install-section.py",
    "lint:prompts": "python3 linter-scripts/check-prompts-loaded.py",
    "lint:strings": "python3 linter-scripts/check-forbidden-strings.py",
    "lint:strings:report": "python3 linter-scripts/forbidden-strings-summary.py",
    "lint:strings:report:md": "python3 linter-scripts/forbidden-strings-summary.py --markdown",
    "lint:fnlen": "python3 linter-scripts/check-function-lengths.py",
    "lint:ci": "bash scripts/lint-ci.sh",
    "lint:ci:list": "bash scripts/lint-ci.sh --list",
    "lint:ci:no-cache": "bash scripts/lint-ci.sh --no-cache",
    "lint:ci:step": "bash scripts/lint-ci.sh --step",
    "lint:ci:from": "bash scripts/lint-ci.sh --from",
    "gen:readme-txt": "node scripts/generate-readme-txt.mjs",
    "prebuild": "node scripts/sync-version.mjs && node scripts/sync-spec-tree.mjs && node scripts/sync-health-score.mjs && node scripts/sync-readme-stats.mjs && python3 linter-scripts/check-readme-canonicals.py && python3 linter-scripts/check-readme-install-section.py",
    "prepare": "husky",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "release": "bash ./release.sh",
    "release:ps1": "powershell -ExecutionPolicy Bypass -File ./release.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "spec:audit": "node scripts/spec-audit/run-audit.mjs",
    "spec:links:check": "python3 linter-scripts/check-spec-cross-links.py --root spec --repo-root .",
    "spec:links:suggest": "python3 linter-scripts/suggest-spec-cross-link-fixes.py --root spec --repo-root .",
    "spec:links:fix": "python3 linter-scripts/suggest-spec-cross-link-fixes.py --root spec --repo-root . --apply",
    "spec:verify:inject": "node scripts/spec-verification/inject-verification-sections.mjs",
    "spec:verify:inject:dry": "node scripts/spec-verification/inject-verification-sections.mjs --dry-run",
    "spec:verify:report": "node scripts/spec-verification/generate-coverage-report.mjs --out reports/spec-verification/coverage.md && node scripts/spec-verification/generate-coverage-report.mjs --json --out reports/spec-verification/coverage.json",
    "spec:verify:report:strict": "node scripts/spec-verification/generate-coverage-report.mjs --out reports/spec-verification/coverage.md --strict && node scripts/spec-verification/generate-coverage-report.mjs --json --out reports/spec-verification/coverage.json --strict",
    "spec:verify:report:all": "node scripts/spec-verification/generate-coverage-report.mjs --mode all-files --out reports/spec-verification/coverage-all-files.md",
    "spec:verify:ci": "node scripts/spec-verification/generate-coverage-report.mjs --strict --out reports/spec-verification/coverage.md",
    "spec:verify:docs": "node scripts/spec-verification/generate-templates-doc.mjs",
    "bundles:generate": "node scripts/generate-bundle-installers.mjs",
    "test:installer": "bash tests/installer/run-tests.sh",
    "test:installer:no-latest": "bash tests/installer/check-no-latest-api.sh",
    "test:installer:acceptance": "bash tests/installer/check-release-install-acceptance.sh",
    "test:installer:bundles": "bash tests/installer/check-bundle-installers.sh",
    "test:release:bake": "bash tests/installer/check-release-bake.sh",
    "test:installer:root": "bash tests/installer/check-root-install-acceptance.sh",
    "test:linters": "python3 linters-cicd/tests/run.py",
    "test:linter-scripts": "python3 linter-scripts/tests/run.py",
    "codegen:verify": "bash linters-cicd/codegen/scripts/verify-codegen-determinism.sh",
    "codegen:regen": "bash linters-cicd/codegen/scripts/regen-codegen-fixtures.sh",
    "test:pipeline:bool-neg": "bash tests/pipeline/check-bool-neg-001-pipeline.sh",
    "test:pipeline:orchestrator": "bash tests/pipeline/check-orchestrator-flags.sh",
    "test:pipeline": "bash tests/pipeline/check-bool-neg-001-pipeline.sh && bash tests/pipeline/check-orchestrator-flags.sh"
  },
