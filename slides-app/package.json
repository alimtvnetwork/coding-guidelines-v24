{
  "name": "slides-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Standalone training slide deck for the coding-guidelines-v24 review curriculum. Builds to a portable HTML/CSS/JS bundle (dist.zip) that runs offline by double-clicking index.html.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/package-zip.mjs",
    "preview": "vite preview",
    "package": "node scripts/package-zip.mjs",
    "ship": "bun run build"
  },
  "dependencies": {
    "@fontsource/ubuntu": "5.1.0",
    "@fontsource/ubuntu-mono": "5.1.0",
    "framer-motion": "11.11.17",
    "lucide-react": "0.460.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "shiki": "1.24.0"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "archiver": "7.0.1",
    "typescript": "5.6.3",
    "vite": "5.4.11"
  }
}
