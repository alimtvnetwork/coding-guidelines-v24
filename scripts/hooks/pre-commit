#!/usr/bin/env bash
# ============================================================
# pre-commit hook — runs all linter-scripts/check-*.sh and
# check-*.py guards before allowing a commit, plus three extra
# phases so derived artifacts can never drift from spec/ edits:
#
#   1. Existing check-*.sh / check-*.py guards
#   2. Spec-only guards (validate-guidelines + cross-link check)
#      — run when staged paths touch spec/ or .lovable/
#   3. Sync scripts (sync-spec-tree + sync-version) — always run;
#      if they produce a diff, the changed artifacts are
#      re-staged automatically so the commit stays consistent.
#
# Install (one-time, per clone):
#   bash scripts/hooks/install-hooks.sh
#
# Bypass (NOT recommended):
#   git commit --no-verify
# ============================================================

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

FAILED=0
RAN=0

run_guard() {
  local script="$1"
  local runner="$2"
  RAN=$((RAN + 1))
  echo ""
  echo "── $script ──"
  if $runner "$script"; then
    echo "✅ pass"
  else
    echo "❌ fail: $script"
    FAILED=$((FAILED + 1))
  fi
}

echo "🪝 pre-commit: running linter-scripts guards..."

# ------------------------------------------------------------
# Phase 0 — fail-fast forbidden-strings gate
# Spec writers see violations (e.g. SPEC19-NO-IMPL) BEFORE any
# other guard noise, with the rule id and matched phrase.
# ------------------------------------------------------------
if [[ -f linter-scripts/check-forbidden-strings.py ]]; then
  echo ""
  echo "🚫 pre-commit: forbidden-strings gate (fail-fast)..."
  if ! python3 linter-scripts/check-forbidden-strings.py; then
    echo ""
    echo "❌ pre-commit BLOCKED: forbidden phrase detected."
    echo "   The rule id and matched phrase are shown above."
    echo "   Fix the offending line, or — if the citation is legitimate —"
    echo "   add an allowlist entry via:"
    echo "     python3 linter-scripts/allowlist-forbidden-string.py \\"
    echo "       --rule <RULE-ID> --reason \"<why>\" <path>"
    echo "   Bypass (NOT recommended): git commit --no-verify"
    exit 1
  fi
  echo "✅ forbidden-strings gate clean."
fi

shopt -s nullglob
for script in linter-scripts/check-*.sh; do
  run_guard "$script" "bash"
done
for script in linter-scripts/check-*.py; do
  # Already ran fail-fast above; skip the duplicate in the generic loop.
  if [[ "$script" == "linter-scripts/check-forbidden-strings.py" ]]; then
    continue
  fi
  run_guard "$script" "python3"
done
shopt -u nullglob

# ------------------------------------------------------------
# Phase 2 — spec-only guards (skip when no spec/.lovable change)
# ------------------------------------------------------------
STAGED="$(git diff --cached --name-only --diff-filter=ACMR || true)"
touched_specs=0
if echo "$STAGED" | grep -qE '^(spec/|\.lovable/)'; then
  touched_specs=1
fi

if [[ "$touched_specs" -eq 1 ]]; then
  echo ""
  echo "📚 pre-commit: spec/.lovable changes detected — running spec guards..."
  if [[ -f linter-scripts/validate-guidelines.py ]]; then
    run_guard "linter-scripts/validate-guidelines.py" "python3"
  fi
  if [[ -f linter-scripts/check-spec-cross-links.py ]]; then
    RAN=$((RAN + 1))
    echo ""
    echo "── linter-scripts/check-spec-cross-links.py ──"
    if python3 linter-scripts/check-spec-cross-links.py --root spec --repo-root .; then
      echo "✅ pass"
    else
      echo "❌ fail: linter-scripts/check-spec-cross-links.py"
      FAILED=$((FAILED + 1))
    fi
  fi
  if [[ -f linter-scripts/check-placeholder-comments.py ]]; then
    RAN=$((RAN + 1))
    echo ""
    echo "── linter-scripts/check-placeholder-comments.py ──"
    if python3 linter-scripts/check-placeholder-comments.py --root spec --repo-root .; then
      echo "✅ pass"
    else
      echo "❌ fail: linter-scripts/check-placeholder-comments.py"
      FAILED=$((FAILED + 1))
    fi
  fi
fi

# ------------------------------------------------------------
# Phase 3 — sync derived artifacts and re-stage any drift
# ------------------------------------------------------------
SYNC_TARGETS=("src/data/specTree.json" "version.json")
SYNC_BEFORE_DIFF=""
for target in "${SYNC_TARGETS[@]}"; do
  if [[ -f "$target" ]]; then
    SYNC_BEFORE_DIFF+="$(sha1sum "$target")"$'\n'
  fi
done

echo ""
echo "🔄 pre-commit: syncing derived artifacts (specTree.json, version.json)..."
SYNC_OK=1
if [[ -f scripts/sync-spec-tree.mjs ]]; then
  if ! node scripts/sync-spec-tree.mjs >/dev/null 2>&1; then
    SYNC_OK=0
    echo "❌ sync-spec-tree.mjs failed"
    FAILED=$((FAILED + 1))
    RAN=$((RAN + 1))
  fi
fi
if [[ -f scripts/sync-version.mjs ]]; then
  if ! node scripts/sync-version.mjs >/dev/null 2>&1; then
    SYNC_OK=0
    echo "❌ sync-version.mjs failed"
    FAILED=$((FAILED + 1))
    RAN=$((RAN + 1))
  fi
fi

if [[ "$SYNC_OK" -eq 1 ]]; then
  SYNC_AFTER_DIFF=""
  for target in "${SYNC_TARGETS[@]}"; do
    if [[ -f "$target" ]]; then
      SYNC_AFTER_DIFF+="$(sha1sum "$target")"$'\n'
    fi
  done
  if [[ "$SYNC_BEFORE_DIFF" != "$SYNC_AFTER_DIFF" ]]; then
    echo "ℹ️  Derived artifacts changed during sync — re-staging:"
    for target in "${SYNC_TARGETS[@]}"; do
      if [[ -f "$target" ]]; then
        git add "$target"
        echo "   + $target"
      fi
    done
  else
    echo "✅ derived artifacts already in sync"
  fi
fi

echo ""
echo "════════════════════════════════════════════════════════════"
if [[ "$RAN" -eq 0 ]]; then
  echo "ℹ️  No guards found under linter-scripts/check-*. Allowing commit."
  exit 0
fi

if [[ "$FAILED" -gt 0 ]]; then
  echo "❌ $FAILED of $RAN guard(s) failed. Commit blocked."
  echo "   Fix the issues above, or bypass with: git commit --no-verify"
  exit 1
fi

echo "✅ All $RAN guard(s) passed. Proceeding with commit."
exit 0
