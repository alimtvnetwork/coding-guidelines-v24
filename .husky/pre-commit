#!/usr/bin/env sh
# ============================================================
# Husky pre-commit
#
# 1. Refresh PascalCase identity + LastCommitSha in version.json
#    (per spec/01-spec-authoring-guide/17-version-schema.md §7.1)
#    and re-stage if changed.
# 2. Verify generated/sync-managed files are up to date.
#    Blocks the commit if `npm run sync:check` fails.
# 3. Run the test suite.
# ============================================================

set -e

node scripts/sync-version.mjs

if ! git diff --quiet -- version.json; then
  git add version.json
  echo "  pre-commit: re-staged version.json (LastCommitSha refreshed)"
fi

if ! npm run --silent sync:check; then
  echo ""
  echo "  pre-commit: sync:check failed — generated files are out of date."
  echo "  Run \`npm run sync\` and stage the regenerated files, then retry the commit."
  exit 1
fi

# Forbidden-strings gate + linter-scripts guards. Surfaces the rule id
# and exact matched phrase (e.g. SPEC19-NO-IMPL) before any test noise.
# Forbidden-strings gate + linter-scripts guards. Surfaces the rule id
# and exact matched phrase (e.g. SPEC19-NO-IMPL) before any test noise.
if [ -x scripts/hooks/pre-commit ]; then
  bash scripts/hooks/pre-commit
fi

# Mermaid validation + render + drift-check. Mirrors diagrams-ci.yml so
# CI failures surface locally before the push. Skip via SKIP_DIAGRAMS_HOOK=1.
if [ -x scripts/hooks/pre-commit-diagrams.sh ]; then
  bash scripts/hooks/pre-commit-diagrams.sh
fi


npm test
